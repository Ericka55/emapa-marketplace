// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  VENDEDOR
  COMPRADOR
}

enum EstadoUsuario {
  ACTIVO
  BLOQUEADO
  INACTIVO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  RECHAZADO
  REEMBOLSADO
}

model Usuario {
  id            Int           @id @default(autoincrement())
  nombre        String
  apellido      String
  email         String        @unique
  password      String
  telefono      String?
  rol           Rol
  estado        EstadoUsuario @default(ACTIVO)
  fechaRegistro DateTime      @default(now())

  sesiones       Sesion[]
  solicitudes    SolicitudVendedor[]
  favoritos      Favorito[]
  carritos         Carrito[]
  resenas        Resena[]
  calificaciones CalificacionVendedor[]
  incidencias    Incidencia[]
  notificaciones Notificacion[]
  auditorias     Auditoria[]

  mensajes                Mensaje[]
  conversacionesComprador Conversacion[] @relation("CompradorConversacion")
  vendedor                Vendedor?
  pedidos                 Pedido[]
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([email])
}

model Sesion {
  id Int @id @default(autoincrement())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  token       String
  ip          String?
  dispositivo String?

  fechaInicio DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EstadoSolicitud {
  id     Int    @id @default(autoincrement())
  nombre String @unique

  solicitudes SolicitudVendedor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SolicitudVendedor {
  id Int @id @default(autoincrement())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  estadoSolicitudId Int
  estadoSolicitud   EstadoSolicitud @relation(fields: [estadoSolicitudId], references: [id])

  motivo String?

  fechaSolicitud DateTime @default(now())

  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  documentos DocumentoSolicitud[]
}

model Vendedor {
  id Int @id @default(autoincrement())

  usuarioId Int     @unique
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  negocio     String
  descripcion String?

  telefonoComercial String?
  whatsapp          String?

  direccion String?

  latitud  Decimal?
  longitud Decimal?

  documentos     DocumentoVendedor[]
  productos      Producto[]
  pedidos        Pedido[]
  calificaciones CalificacionVendedor[]
  conversaciones Conversacion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentoSolicitud {
  id Int @id @default(autoincrement())

  solicitudId Int
  solicitud   SolicitudVendedor @relation(fields: [solicitudId], references: [id])

  tipo String

  archivo String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentoVendedor {
  id Int @id @default(autoincrement())

  vendedorId Int
  vendedor   Vendedor @relation(fields: [vendedorId], references: [id])

  tipo    String
  archivo String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categoria {
  id Int @id @default(autoincrement())

  nombre      String  @unique
  descripcion String?

  productos Producto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Producto {
  id Int @id @default(autoincrement())

  vendedorId Int
  vendedor   Vendedor @relation(fields: [vendedorId], references: [id])

  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  nombre      String
  descripcion String

  precio Decimal @db.Decimal(10, 2)

  stock Int

  estado Boolean @default(true)

  imagenes ImagenProducto[]

  favoritos Favorito[]

  detallesPedido DetallePedido[]
  carritosDetalle    CarritoDetalle[]

  resenas Resena[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nombre])
  @@index([categoriaId])
  @@index([vendedorId])
}

model ImagenProducto {
  id Int @id @default(autoincrement())

  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])

  urlImagen String

  principal Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorito {
  id Int @id @default(autoincrement())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioId, productoId])
}

model EstadoPedido {
  id Int @id @default(autoincrement())

  nombre String @unique

  pedidos Pedido[]

  historial HistorialPedido[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pedido {
  id Int @id @default(autoincrement())

  compradorId Int
  comprador   Usuario @relation(fields: [compradorId], references: [id])

  vendedorId Int
  vendedor   Vendedor @relation(fields: [vendedorId], references: [id])

  estadoPedidoId Int
  estadoPedido   EstadoPedido @relation(fields: [estadoPedidoId], references: [id])

  total            Decimal @db.Decimal(12, 2)
  direccionEntrega String

  telefonoContacto String

  observaciones String?

  fechaPedido DateTime @default(now())

  detalles DetallePedido[]

  historial HistorialPedido[]

  pagos Pago[]

  incidencias Incidencia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([compradorId])
  @@index([vendedorId])
}

model DetallePedido {
  id Int @id @default(autoincrement())

  pedidoId Int
  pedido   Pedido @relation(fields: [pedidoId], references: [id])

  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])

  cantidad Int

  precioUnitario Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HistorialPedido {
  id Int @id @default(autoincrement())

  pedidoId Int
  pedido   Pedido @relation(fields: [pedidoId], references: [id])

  estadoPedidoId Int
  estadoPedido   EstadoPedido @relation(fields: [estadoPedidoId], references: [id])

  fecha DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversacion {
  id Int @id @default(autoincrement())

  compradorId Int
  comprador   Usuario @relation("CompradorConversacion", fields: [compradorId], references: [id])

  vendedorId Int
  vendedor   Vendedor @relation(fields: [vendedorId], references: [id])

  mensajes Mensaje[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([compradorId])
  @@index([vendedorId])
}

model Mensaje {
  id Int @id @default(autoincrement())

  conversacionId Int
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id])

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  mensaje String @db.Text

  leido Boolean @default(false)

  fechaEnvio DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversacionId])
}

model Resena {
  id Int @id @default(autoincrement())

  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  estrellas Int

  comentario String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productoId, usuarioId])
}

model CalificacionVendedor {
  id Int @id @default(autoincrement())

  vendedorId Int
  vendedor   Vendedor @relation(fields: [vendedorId], references: [id])

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  puntuacion Int

  comentario String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendedorId, usuarioId])
}

model EstadoIncidencia {
  id Int @id @default(autoincrement())

  nombre String @unique

  incidencias Incidencia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Incidencia {
  id Int @id @default(autoincrement())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  pedidoId Int
  pedido   Pedido @relation(fields: [pedidoId], references: [id])

  estadoIncidenciaId Int
  estadoIncidencia   EstadoIncidencia @relation(fields: [estadoIncidenciaId], references: [id])

  descripcion String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notificacion {
  id Int @id @default(autoincrement())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  titulo String

  mensaje String @db.Text

  leido Boolean @default(false)

  fecha DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Auditoria {
  id Int @id @default(autoincrement())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  accion String

  tablaAfectada String

  ip String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Carrito {
  id              Int               @id @default(autoincrement())

  usuarioId       Int
  usuario         Usuario           @relation(fields: [usuarioId], references: [id])

  activo          Boolean           @default(true)

  detalles        CarritoDetalle[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([usuarioId])
}

model CarritoDetalle {
  id              Int               @id @default(autoincrement())

  carritoId       Int
  carrito         Carrito           @relation(fields: [carritoId], references: [id])

  productoId      Int
  producto        Producto          @relation(fields: [productoId], references: [id])

  cantidad        Int

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([carritoId, productoId])
}

model MetodoPago {
  id Int @id @default(autoincrement())

  nombre String @unique

  activo Boolean @default(true)

  pagos Pago[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pago {
  id Int @id @default(autoincrement())

  pedidoId Int
  pedido   Pedido @relation(fields: [pedidoId], references: [id])

  metodoPagoId Int
  metodoPago   MetodoPago @relation(fields: [metodoPagoId], references: [id])

  monto Decimal @db.Decimal(10, 2)

  estado EstadoPago

  referencia String?

  fechaPago DateTime?

  transacciones Transaccion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pedidoId])
}

model Transaccion {
  id Int @id @default(autoincrement())

  pagoId Int
  pago   Pago @relation(fields: [pagoId], references: [id])

  codigoTransaccion String

  respuestaPasarela String?

  fecha DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
